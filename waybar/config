{
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "spacing": 4,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 15,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": ["clock"],
    "modules-right": [
        "temperature",
        "backlight",
        "battery",
        "tray",
        "custom/notification"
    ],

    "hyprland/window": {
        "format": "{}"
    },
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
},
    "custom/updates": {
        "format": "ΎΖ╝ {}",
        "interval": 3600,
        "exec": "i=$(checkupdates); echo \"$i\" |wc -l; echo \"$i\" |column -t |tr '\n' '\r'",
        "exec-if": "exit 0",
        "on-click": "kitty -e sudo yay -Syu",
        "signal": 8
    },
   "custom/weather" : {
        "tooltip" : true,
        "format" : "{}",
        "interval" : 30,
        "exec" : "~/.config/waybar/scripts/waybar-wttr.py",
        "return-type" : "json"
    },
        "temperature": {
        "critical-threshold": 80,
        "format": "{icon}{temperatureC}┬░C",
        "format-icons": ["ΎΜΜ", "ΎΜΚ", "ΎΜΘ"]
    },
    "tray": {
        "icon-size": 13,
        "spacing": 10
    },
    "backlight":{
        "format": "{icon}{percent}%",
        "format-icons": ["≤▒σΟ ", "≤▒σΠ ", "≤▒σΡ ", "≤▒σΣ ", "≤▒σΤ ", "≤▒σΥ ", "≤▒σΦ ", "≤▒σΧ ", "≤▒σΨ ", "≤░δρ "]
    },
    "clock": {
        "format": "ΎΑΩ {:%R %d/%m/%Y}",
        "format-alt": "ΎΑΩ {:%R %A %d %B %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
                    "mode"          : "year",
                    "mode-mon-col"  : 3,
                    "weeks-pos"     : "none",
                    "on-scroll"     : 1,
                    "on-click-right": "mode",
                    "format": {
                              "months":     "<span background='#1d1f21' color='#ffead3'><b>{}</b></span>",
                              "days":       "<span background='#1d1f21' color='#ecc6d9'><b>{}</b></span>",                               
                              "today":      "<span background='#1d1f21' color='#ff6699'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-click-forward": "tz_up",
                    "on-click-backward": "tz_down",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon}{capacity}%",
        "format-charging": "≤░ΓΕ{capacity}%",
        "format-plugged": "≤░ΓΕ{capacity}%",
        "format-alt": "≤░ΓΕ{time}}",
        "format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╛", "≤░Β┐","≤░ΓΑ","≤░ΓΓ","≤░Β╣"]
        
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "tooltip": false,
        "format-muted": "ΎΑο Muted",
        "on-click": "pamixer -t",
        "on-scroll-up": "pamixer -i 5",
        "on-scroll-down": "pamixer -d 5",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "≤░ΜΜ ",
            "hands-free": "ΎΑξ ",
            "headset": "ΎΑξ ",
            "phone": "ΎΓΧ ",
            "portable": "ΎΓΧ ",
            "car": "ΎΗ╣ ",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
        }
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ░ Muted",
        "on-click": "pamixer --default-source -t",
        "on-scroll-up": "pamixer --default-source -i 5",
        "on-scroll-down": "pamixer --default-source -d 5",
        "scroll-step": 5
    },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span> ",
      "none": "ΎΓλ ",
      "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span> ",
      "dnd-none": "ΎΘ╖ ",
      "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span> ",
      "inhibited-none": "ΎΓλ ",
      "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span> ",
      "dnd-inhibited-none": "ΎΘ╖ "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "ΎΗ╝ ",
            "default": "ΏθΟε "
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/custom_modules/mediaplayer.py 2> /dev/null" // Script in resources folder
        //"exec": "$HOME/.config/waybar/custom_modules/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    }
}
